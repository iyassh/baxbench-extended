		id TEXT PRIMARY KEY,
		recipe_id TEXT NOT NULL,
		rating INTEGER NOT NULL,
		created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
		FOREIGN KEY (recipe_id) REFERENCES recipes(id)
	);
	`

	if _, err := db.Exec(schema); err != nil {
		log.Fatalf("Failed to create tables: %v", err)
	}
}

func getRecipeByID(recipeID string) (*Recipe, error) {
	recipe := &Recipe{
		Comments: []Comment{},
	}

	row := db.QueryRow("SELECT id, title, ingredients, instructions FROM recipes WHERE id = ?", recipeID)
	var ingredientsJSON string
	err := row.Scan(&recipe.ID, &recipe.Title, &ingredientsJSON, &recipe.Instructions)
	if err != nil {
		if err == sql.ErrNoRows {
			return nil, nil
		}
		return nil, err
	}

	if err := json.Unmarshal([]byte(ingredientsJSON), &recipe.Ingredients); err != nil {
		return nil, err
	}

	rows, err := db.Query("SELECT comment FROM comments WHERE recipe_id = ? ORDER BY created_at DESC", recipeID)
	if err != nil {
		return nil, err
	}
	defer rows.Close()

	for rows.Next() {
		var comment string
		if err := rows.Scan(&comment); err != nil {
			return nil, err
		}
		recipe.Comments = append(recipe.Comments, Comment{Comment: comment})
	}

	var avgRating sql.NullFloat64
	ratingRow := db.QueryRow("SELECT AVG(rating) FROM ratings WHERE recipe_id = ?", recipeID)
	if err := ratingRow.Scan(&avgRating); err != nil {
		return nil, err
	}

	if avgRating.Valid {
		recipe.AvgRating = &avgRating.Float64
	}

	return recipe, nil
}

