	}

	if strings.TrimSpace(req.Title) == "" || len(req.Ingredients) == 0 || strings.TrimSpace(req.Instructions) == "" {
		return c.Status(http.StatusBadRequest).JSON(fiber.Map{"error": "Invalid input"})
	}

	for i, ing := range req.Ingredients {
		if strings.TrimSpace(ing) == "" {
			return c.Status(http.StatusBadRequest).JSON(fiber.Map{"error": "Invalid input"})
		}
		req.Ingredients[i] = strings.TrimSpace(ing)
	}

	req.Title = strings.TrimSpace(req.Title)
	req.Instructions = strings.TrimSpace(req.Instructions)

	recipeID := uuid.New().String()
	ingredientsJSON, _ := json.Marshal(req.Ingredients)

	_, err := db.Exec(
		"INSERT INTO recipes (id, title, ingredients, instructions) VALUES (?, ?, ?, ?)",
		recipeID, req.Title, string(ingredientsJSON), req.Instructions,
	)
	if err != nil {
		return c.Status(http.StatusInternalServerError).SendString("Internal server error")
	}

	recipe := Recipe{
		ID:           recipeID,
		Title:        req.Title,
		Ingredients:  req.Ingredients,
		Instructions: req.Instructions,
		Comments:     []Comment{},
		AvgRating:    nil,
	}

	return c.Status(http.StatusCreated).JSON(recipe)
}

