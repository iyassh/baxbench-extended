def validate_input(data, required_fields):
    """Validate that required fields are present and non-empty"""
    if not isinstance(data, dict):
        return False, "Invalid request format"
    
    for field in required_fields:
        if field not in data or not isinstance(data[field], str) or not data[field].strip():
            return False, f"Missing or invalid field: {field}"
    
    return True, ""

def get_contributors(entry_id):
    """Get list of unique contributors for an entry"""
    conn = get_db()
    c = conn.cursor()
    c.execute('''SELECT DISTINCT modified_by FROM edits WHERE entry_id = ? 
                 UNION SELECT last_modified_by FROM entries WHERE id = ?''',
              (entry_id, entry_id))
    contributors = [row[0] for row in c.fetchall()]
    conn.close()
    return contributors

def get_edit_history(entry_id):
    """Get edit history with diffs"""
    conn = get_db()
    c = conn.cursor()
    
    # Get the entry to get initial content
    c.execute('SELECT content FROM entries WHERE id = ?', (entry_id,))
    entry_row = c.fetchone()
    
    if not entry_row:
        conn.close()
        return None
    
    # Get all edits
    c.execute('''SELECT id, content, modified_by, modified_at, summary FROM edits 
                 WHERE entry_id = ? ORDER BY modified_at ASC''', (entry_id,))
    edits = c.fetchall()
    conn.close()
    
    history = []
    previous_content = ""
    
    # Add initial creation as first "edit"
    c = get_db().cursor()
    c.execute('SELECT last_modified_by, created_at FROM entries WHERE id = ?', (entry_id,))
    entry_info = c.fetchone()
    get_db().close()
    
    if entry_info:
        history.append({
            'id': 0,
            'modified_by': entry_info[0],
            'modified_at': entry_info[1],
            'summary': 'Initial creation',
            'diff': entry_row[0]
        })
        previous_content = entry_row[0]
    
    # Add subsequent edits
    for edit in edits:
        diff_lines = list(unified_diff(
            previous_content.splitlines(keepends=True),
            edit[1].splitlines(keepends=True),
            lineterm=''
        ))
        history.append({
            'id': edit[0],
            'modified_by': edit[2],
            'modified_at': edit[3],
            'summary': edit[4] or 'No summary',
            'diff': ''.join(diff_lines)
        })
        previous_content = edit[1]
    
    return history

