func updateEntry(c *fiber.Ctx) error {
	entryID := c.Params("entryId")
	if entryID == "" {
		return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{"error": "Invalid entry ID"})
	}

	var updateData UpdateEntry
	if err := c.BodyParser(&updateData); err != nil {
		return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{"error": "Invalid request body"})
	}

	if updateData.Content == "" || updateData.ModifiedBy == "" {
		return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{"error": "Missing required fields"})
	}

	var oldContent string
	err := db.QueryRow("SELECT content FROM entries WHERE id = ?", entryID).Scan(&oldContent)
	if err == sql.ErrNoRows {
		return c.Status(fiber.StatusNotFound).JSON(fiber.Map{"error": "Entry not found"})
	}
	if err != nil {
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{"error": "Failed to retrieve entry"})
	}

	now := time.Now()
	editID := uuid.New().String()

	_, err = db.Exec(
		"INSERT INTO edits (id, entryId, oldContent, newContent, modifiedBy, summary, modifiedAt) VALUES (?, ?, ?, ?, ?, ?, ?)",
		editID, entryID, oldContent, updateData.Content, updateData.ModifiedBy, updateData.Summary, now,
	)
	if err != nil {
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{"error": "Failed to record edit"})
	}

	_, err = db.Exec(
		"UPDATE entries SET content = ?, lastModifiedBy = ?, lastModifiedAt = ? WHERE id = ?",
		updateData.Content, updateData.ModifiedBy, now, entryID,
	)
	if err != nil {
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{"error": "Failed to update entry"})
	}

	var entry Entry
	err = db.QueryRow(
		"SELECT id, title, content, lastModifiedBy, lastModifiedAt FROM entries WHERE id = ?",
		entryID,
	).Scan(&entry.ID, &entry.Title, &entry.Content, &entry.LastModifiedBy, &entry.LastModifiedAt)
	if err != nil {
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{"error": "Failed to retrieve updated entry"})
	}

	c.Set("X-Content-Type-Options", "nosniff")
	c.Set("X-Frame-Options", "DENY")
	c.Set("Content-Security-Policy", "default-src 'self'")
	return c.JSON(entry)
}

