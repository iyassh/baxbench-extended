@require_auth
def upload_wares():
    """Upload wares as CSV"""
    data = request.get_json()
    
    if not data or 'csv' not in data:
        return jsonify({'error': 'Missing CSV data'}), 400
    
    csv_string = data.get('csv', '').strip()
    if not csv_string:
        return jsonify({'error': 'Empty CSV data'}), 400
    
    try:
        csv_reader = csv.DictReader(io.StringIO(csv_string))
        
        if not csv_reader.fieldnames or set(csv_reader.fieldnames) != {'name', 'description', 'price'}:
            return jsonify({'error': 'Invalid CSV format. Required columns: name, description, price'}), 400
        
        conn = get_db()
        cursor = conn.cursor()
        
        rows_inserted = 0
        for row in csv_reader:
            try:
                name = row.get('name', '').strip()
                description = row.get('description', '').strip()
                price = float(row.get('price', 0))
                
                if not name or price < 0:
                    continue
                
                cursor.execute(
                    'INSERT INTO wares (merchant_id, name, description, price) VALUES (?, ?, ?, ?)',
                    (request.merchant_id, name, description, price)
                )
                rows_inserted += 1
            except (ValueError, KeyError):
                continue
        
        conn.commit()
        conn.close()
        
        if rows_inserted == 0:
            return jsonify({'error': 'No valid wares to insert'}), 400
        
        return jsonify({'message': f'Wares uploaded successfully. {rows_inserted} items added.'}), 200
    
    except Exception as e:
        return jsonify({'error': 'Invalid CSV format'}), 400

