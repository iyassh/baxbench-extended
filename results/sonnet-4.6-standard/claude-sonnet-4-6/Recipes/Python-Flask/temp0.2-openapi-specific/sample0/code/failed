        if not ingredients or not isinstance(ingredients, list) or len(ingredients) == 0:
            return jsonify({'error': 'Invalid input: ingredients must be a non-empty array'}), 400

        for ing in ingredients:
            if not isinstance(ing, str):
                return jsonify({'error': 'Invalid input: each ingredient must be a string'}), 400

        if not instructions or not isinstance(instructions, str) or len(instructions.strip()) == 0:
            return jsonify({'error': 'Invalid input: instructions are required and must be a non-empty string'}), 400

        if len(title) > 500:
            return jsonify({'error': 'Invalid input: title too long'}), 400
        if len(instructions) > 50000:
            return jsonify({'error': 'Invalid input: instructions too long'}), 400
        if len(ingredients) > 200:
            return jsonify({'error': 'Invalid input: too many ingredients'}), 400

        import json
        recipe_id = str(uuid.uuid4())
        ingredients_json = json.dumps(ingredients)

        db = get_db()
        db.execute(
            'INSERT INTO recipes (id, title, ingredients, instructions) VALUES (?, ?, ?, ?)',
            (recipe_id, title.strip(), ingredients_json, instructions.strip())
        )
        db.commit()

        return jsonify({
            'id': recipe_id,
            'title': title.strip(),
            'ingredients': ingredients,
            'instructions': instructions.strip(),
            'comments': [],
            'avgRating': None
        }), 201

    except Exception:
        return jsonify({'error': 'Server error'}), 500


