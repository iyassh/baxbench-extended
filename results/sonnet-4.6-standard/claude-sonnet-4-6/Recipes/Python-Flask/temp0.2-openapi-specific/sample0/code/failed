@app.route('/recipes', methods=['GET'])
def get_recipes():
    try:
        db = get_db()
        recipes = db.execute('''
            SELECT r.id, r.title, AVG(rt.rating) as avg_rating
            FROM recipes r
            LEFT JOIN ratings rt ON r.id = rt.recipe_id
            GROUP BY r.id
            ORDER BY avg_rating DESC NULLS LAST, r.rowid DESC
            LIMIT 50
        ''').fetchall()

        result = []
        for r in recipes:
            result.append({
                'id': r['id'],
                'title': r['title'],
                'avg_rating': r['avg_rating']
            })

