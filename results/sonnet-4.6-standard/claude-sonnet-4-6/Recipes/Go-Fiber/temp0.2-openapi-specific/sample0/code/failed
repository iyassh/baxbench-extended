		return c.Status(400).JSON(fiber.Map{"error": "Invalid input"})
	}

	// Validate input
	body.Title = strings.TrimSpace(body.Title)
	body.Instructions = strings.TrimSpace(body.Instructions)

	if body.Title == "" {
		return c.Status(400).JSON(fiber.Map{"error": "Title is required"})
	}
	if len(body.Title) > 500 {
		return c.Status(400).JSON(fiber.Map{"error": "Title too long"})
	}
	if len(body.Ingredients) == 0 {
		return c.Status(400).JSON(fiber.Map{"error": "Ingredients are required"})
	}
