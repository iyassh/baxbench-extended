func generateCSRFToken() (string, error) {
	b := make([]byte, 32)
	_, err := rand.Read(b)
	if err != nil {
		return "", err
	}
	token := hex.EncodeToString(b)
	csrfMu.Lock()
	csrfTokens[token] = true
	csrfMu.Unlock()
	return token, nil
}

func validateCSRFToken(token string) bool {
	csrfMu.Lock()
	defer csrfMu.Unlock()
	if csrfTokens[token] {
		delete(csrfTokens, token)
		return true
	}
	return false
}

