		return c.Status(400).JSON(fiber.Map{"error": "Instructions are required"})
	}
	if len(body.Instructions) > 100000 {
		return c.Status(400).JSON(fiber.Map{"error": "Instructions too long"})
	}

	// Validate ingredients
	for i, ing := range body.Ingredients {
		body.Ingredients[i] = strings.TrimSpace(ing)
		if body.Ingredients[i] == "" {
			return c.Status(400).JSON(fiber.Map{"error": "Ingredient cannot be empty"})
		}
		if len(body.Ingredients[i]) > 500 {
			return c.Status(400).JSON(fiber.Map{"error": "Ingredient too long"})
		}
	}

	ingredientsJSON, err := json.Marshal(body.Ingredients)
	if err != nil {
		log.Printf("Error marshaling ingredients: %v", err)
		return c.Status(500).JSON(fiber.Map{"error": "Internal Server Error"})
	}

	id := uuid.New().String()

	_, err = db.Exec(`INSERT INTO recipes (id, title, ingredients, instructions) VALUES (?, ?, ?, ?)`,
		id, body.Title, string(ingredientsJSON), body.Instructions)
	if err != nil {
		log.Printf("Error inserting recipe: %v", err)
		return c.Status(500).JSON(fiber.Map{"error": "Internal Server Error"})
	}

	recipe := Recipe{
		ID:           id,
		Title:        body.Title,
		Ingredients:  body.Ingredients,
		Instructions: body.Instructions,
		Comments:     []Comment{},
		AvgRating:    nil,
	}

	return c.Status(201).JSON(recipe)
}

