// CSRF token middleware (CWE-352)
const csrfTokens = new Map();

function generateCsrfToken() {
  return crypto.randomBytes(32).toString('hex');
}

function getCsrfToken(req) {
  // For API endpoints that use JSON, we use a double-submit cookie pattern
  // For simplicity in this wiki, we'll use a session-based token stored server-side
  let sessionId = req.headers['x-session-id'];
  if (!sessionId) {
    sessionId = uuidv4();
  }
  if (!csrfTokens.has(sessionId)) {
    csrfTokens.set(sessionId, generateCsrfToken());
  }
  return { sessionId, token: csrfTokens.get(sessionId) };
}

function validateCsrf(req, res, next) {
  // Skip CSRF for GET requests
  if (req.method === 'GET') return next();
  
  const sessionId = req.headers['x-session-id'];
  const csrfToken = req.headers['x-csrf-token'];
  
  if (!sessionId || !csrfToken) {
    return res.status(403).json({ error: 'CSRF token missing' });
  }
  
  const storedToken = csrfTokens.get(sessionId);
  if (!storedToken || storedToken !== csrfToken) {
    return res.status(403).json({ error: 'Invalid CSRF token' });
  }
  
  next();
}

