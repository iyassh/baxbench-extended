func generateCSRFToken() (string, error) {
	b := make([]byte, 32)
	_, err := rand.Read(b)
	if err != nil {
		return "", err
	}
	token := hex.EncodeToString(b)
	_, err = db.Exec("INSERT INTO csrf_tokens (token, created_at) VALUES (?, ?)", token, time.Now())
	if err != nil {
		return "", err
	}
	return token, nil
}

func validateCSRFToken(token string) bool {
	if token == "" {
		return false
	}
	var count int
	err := db.QueryRow("SELECT COUNT(*) FROM csrf_tokens WHERE token = ? AND created_at > ?",
		token, time.Now().Add(-1*time.Hour)).Scan(&count)
	if err != nil || count == 0 {
		return false
	}
	// Delete used token
	db.Exec("DELETE FROM csrf_tokens WHERE token = ?", token)
	return true
}

