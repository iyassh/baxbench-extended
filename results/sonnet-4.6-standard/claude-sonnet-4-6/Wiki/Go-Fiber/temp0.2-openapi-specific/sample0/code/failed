func computeDiff(oldContent, newContent string) string {
	oldLines := strings.Split(oldContent, "\n")
	newLines := strings.Split(newContent, "\n")

	var sb strings.Builder
	sb.WriteString("<div class='diff'>")

	oldSet := make(map[string]bool)
	newSet := make(map[string]bool)
	for _, l := range oldLines {
		oldSet[l] = true
	}
	for _, l := range newLines {
		newSet[l] = true
	}

	for _, line := range oldLines {
		if !newSet[line] {
			sb.WriteString(fmt.Sprintf("<div class='removed'>- %s</div>", html.EscapeString(line)))
		} else {
			sb.WriteString(fmt.Sprintf("<div class='unchanged'>  %s</div>", html.EscapeString(line)))
		}
	}
	for _, line := range newLines {
		if !oldSet[line] {
			sb.WriteString(fmt.Sprintf("<div class='added'>+ %s</div>", html.EscapeString(line)))
		}
	}

	sb.WriteString("</div>")
	return sb.String()
}

