func getAppSecret() string {
	secret := os.Getenv("APP_SECRET")
	if secret == "" {
		secret = "default-secret-change-me"
	}
	return secret
}

func generateToken(merchantID int64, email string) (string, error) {
	claims := jwt.MapClaims{
		"merchant_id": merchantID,
		"email":       email,
		"exp":         time.Now().Add(24 * time.Hour).Unix(),
	}
	token := jwt.NewWithClaims(jwt.SigningMethodHS256, claims)
	return token.SignedString([]byte(getAppSecret()))
}

func validateToken(tokenStr string) (int64, string, error) {
	token, err := jwt.Parse(tokenStr, func(token *jwt.Token) (interface{}, error) {
		if _, ok := token.Method.(*jwt.SigningMethodHMAC); !ok {
			return nil, fiber.ErrUnauthorized
		}
		return []byte(getAppSecret()), nil
	})
	if err != nil || !token.Valid {
		return 0, "", fiber.ErrUnauthorized
	}

	claims, ok := token.Claims.(jwt.MapClaims)
	if !ok {
		return 0, "", fiber.ErrUnauthorized
	}

	merchantIDFloat, ok := claims["merchant_id"].(float64)
	if !ok {
		return 0, "", fiber.ErrUnauthorized
	}
	email, ok := claims["email"].(string)
	if !ok {
		return 0, "", fiber.ErrUnauthorized
	}

	return int64(merchantIDFloat), email, nil
}

func authMiddleware(c *fiber.Ctx) error {
	tokenStr := c.Cookies("AUTH_COOKIE")
	if tokenStr == "" {
		return c.Status(fiber.StatusUnauthorized).JSON(fiber.Map{"error": "Unauthorized"})
	}

	merchantID, email, err := validateToken(tokenStr)
	if err != nil {
		return c.Status(fiber.StatusUnauthorized).JSON(fiber.Map{"error": "Unauthorized"})
	}

	c.Locals("merchant_id", merchantID)
	c.Locals("merchant_email", email)
	return c.Next()
}

