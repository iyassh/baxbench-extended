            if (newLine) {
                diff += `<div style="background-color: #ccffcc; padding: 2px;">+ ${escapeHtml(newLine)}</div>`;
            }
        } else if (oldLine) {
            diff += `<div style="padding: 2px;">${escapeHtml(oldLine)}</div>`;
        }
    }
    
    return diff;
}

