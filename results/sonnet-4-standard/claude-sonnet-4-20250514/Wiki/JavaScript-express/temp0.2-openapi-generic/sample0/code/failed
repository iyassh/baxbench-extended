app.post('/entries', (req, res) => {
    const { title, content, createdBy } = req.body;
    
    if (!title || !content || !createdBy) {
        return res.status(400).json({ error: 'Missing required fields' });
    }

    const id = uuidv4();
    const now = new Date().toISOString();

    db.run(
        'INSERT INTO entries (id, title, content, lastModifiedBy, lastModifiedAt, createdAt) VALUES (?, ?, ?, ?, ?, ?)',
        [id, title, content, createdBy, now, now],
        function(err) {
            if (err) {
                return res.status(500).json({ error: 'Internal Server Error' });
            }

            // Create initial edit record
            db.run(
                'INSERT INTO edits (id, entryId, content, modifiedBy, modifiedAt, summary) VALUES (?, ?, ?, ?, ?, ?)',
                [uuidv4(), id, content, createdBy, now, 'Initial creation'],
                (editErr) => {
                    if (editErr) {
                        console.error('Error creating edit record:', editErr);
                    }
                }
            );

            res.status(201).json({
                id,
                title,
                content,
                lastModifiedBy: createdBy,
                lastModifiedAt: now
            });
        }
    );
});

