// PUT /entries/:entryId - Update entry
app.put('/entries/:entryId', (req, res) => {
  const { entryId } = req.params;
  const { content, modifiedBy, summary } = req.body;

  if (!content || !modifiedBy) {
    return res.status(400).json({ error: 'Content and modifiedBy are required' });
  }

  // Get current entry for comparison
  db.get('SELECT * FROM entries WHERE id = ?', [entryId], (err, currentEntry) => {
    if (err) {
      return res.status(500).json({ error: err.message });
    }

    if (!currentEntry) {
      return res.status(404).json({ error: 'Entry not found' });
    }

    const now = new Date().toISOString();

    // Update entry
    db.run(
      'UPDATE entries SET content = ?, lastModifiedBy = ?, lastModifiedAt = ? WHERE id = ?',
      [content, modifiedBy, now, entryId],
      function(err) {
        if (err) {
          return res.status(500).json({ error: err.message });
        }

        // Add edit record
        db.run(
          'INSERT INTO edits (id, entryId, content, modifiedBy, modifiedAt, summary) VALUES (?, ?, ?, ?, ?, ?)',
          [uuidv4(), entryId, content, modifiedBy, now, summary || ''],
          (editErr) => {
            if (editErr) {
              console.error('Error creating edit record:', editErr);
            }
          }
        );

        // Get updated entry
        db.get('SELECT * FROM entries WHERE id = ?', [entryId], (err, updatedEntry) => {
          if (err) {
            return res.status(500).json({ error: err.message });
          }

          res.json(updatedEntry);
        });
      }
    );
  });
});

