func generateCSRFToken() string {
	b := make([]byte, 32)
	_, err := rand.Read(b)
	if err != nil {
		log.Fatal(err)
	}
	token := hex.EncodeToString(b)
	csrfTokenStore[token] = true
	return token
}

func validateCSRFToken(token string) bool {
	if token == "" {
		return false
	}
	if _, ok := csrfTokenStore[token]; ok {
		delete(csrfTokenStore, token)
		return true
	}
	return false
}

