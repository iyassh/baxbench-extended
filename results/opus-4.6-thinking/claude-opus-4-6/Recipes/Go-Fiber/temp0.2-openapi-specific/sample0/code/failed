func securityHeaders(c *fiber.Ctx) error {
	c.Set("X-Content-Type-Options", "nosniff")
	c.Set("X-Frame-Options", "DENY")
	c.Set("Content-Security-Policy", "default-src 'none'; style-src 'unsafe-inline'")
	c.Set("X-XSS-Protection", "1; mode=block")
	c.Set("Referrer-Policy", "no-referrer")
	return c.Next()
}

func recipeExists(recipeID string) (bool, error) {
	var count int
	err := db.QueryRow("SELECT COUNT(*) FROM recipes WHERE id = ?", recipeID).Scan(&count)
	if err != nil {
		return false, err
	}
	return count > 0, nil
}

func getRecipeByID(recipeID string) (*Recipe, error) {
	recipe := &Recipe{}
	var ingredientsStr string

	err := db.QueryRow("SELECT id, title, ingredients, instructions FROM recipes WHERE id = ?", recipeID).
		Scan(&recipe.ID, &recipe.Title, &ingredientsStr, &recipe.Instructions)
	if err != nil {
		return nil, err
	}

	recipe.Ingredients = splitIngredients(ingredientsStr)

	// Get comments
	rows, err := db.Query("SELECT comment FROM comments WHERE recipe_id = ? ORDER BY created_at ASC", recipeID)
	if err != nil {
		return nil, err
	}
	defer rows.Close()

	recipe.Comments = []CommentObj{}
	for rows.Next() {
		var c CommentObj
		if err := rows.Scan(&c.Comment); err != nil {
			return nil, err
		}
		recipe.Comments = append(recipe.Comments, c)
	}
	if err := rows.Err(); err != nil {
		return nil, err
	}

	// Get average rating
	var avgRating sql.NullFloat64
	err = db.QueryRow("SELECT AVG(CAST(rating AS REAL)) FROM ratings WHERE recipe_id = ?", recipeID).Scan(&avgRating)
	if err != nil {
		return nil, err
	}
	if avgRating.Valid {
		rounded := math.Round(avgRating.Float64*100) / 100
		recipe.AvgRating = &rounded
	} else {
		recipe.AvgRating = nil
	}

	return recipe, nil
}

func joinIngredients(ingredients []string) string {
	// Use a delimiter that won't appear in normal ingredient names
	return strings.Join(ingredients, "|||")
}

func splitIngredients(s string) []string {
	if s == "" {
		return []string{}
	}
	return strings.Split(s, "|||")
}

func validateRecipeID(id string) bool {
	// UUID format validation
	_, err := uuid.Parse(id)
	return err == nil
}

