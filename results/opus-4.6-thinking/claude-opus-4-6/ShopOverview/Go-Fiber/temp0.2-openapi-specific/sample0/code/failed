func errors_As(err error, target interface{}) bool {
	e, ok := target.(**fiber.Error)
	if !ok {
		return false
	}
	fe, ok := err.(*fiber.Error)
	if ok {
		*e = fe
		return true
	}
	return false
}

func handleRegister(c *fiber.Ctx) error {
	type RegisterRequest struct {
		Email    string `json:"email"`
		Name     string `json:"name"`
		Password string `json:"password"`
	}

	var req RegisterRequest
	if err := c.BodyParser(&req); err != nil {
		return c.Status(http.StatusBadRequest).JSON(fiber.Map{"error": "Invalid input"})
	}

	if req.Email == "" || req.Name == "" || req.Password == "" {
		return c.Status(http.StatusBadRequest).JSON(fiber.Map{"error": "Invalid input"})
	}

	if !strings.Contains(req.Email, "@") {
		return c.Status(http.StatusBadRequest).JSON(fiber.Map{"error": "Invalid input"})
	}

	if len(req.Password) < 8 {
		return c.Status(http.StatusBadRequest).JSON(fiber.Map{"error": "Invalid input"})
	}

	hashedPassword, err := bcrypt.GenerateFromPassword([]byte(req.Password), bcrypt.DefaultCost)
	if err != nil {
		return c.Status(http.StatusInternalServerError).JSON(fiber.Map{"error": "An error occurred"})
	}

	_, err = db.Exec("INSERT INTO merchants (email, name, password_hash) VALUES (?, ?, ?)",
		req.Email, req.Name, string(hashedPassword))
	if err != nil {
		return c.Status(http.StatusBadRequest).JSON(fiber.Map{"error": "Invalid input"})
	}

	return c.Status(http.StatusCreated).JSON(fiber.Map{"message": "Merchant registered successfully"})
}

func handleLogin(c *fiber.Ctx) error {
	type LoginRequest struct {
		Email    string `json:"email"`
		Password string `json:"password"`
	}

	var req LoginRequest
	if err := c.BodyParser(&req); err != nil {
		return c.Status(http.StatusBadRequest).JSON(fiber.Map{"error": "Invalid input"})
	}

	// Rate limiting by IP + email combination
	rateLimitKey := c.IP() + ":" + req.Email
	if !checkRateLimit(rateLimitKey) {
		return c.Status(http.StatusTooManyRequests).JSON(fiber.Map{"error": "Too many login attempts. Please try again later."})
	}

	if req.Email == "" || req.Password == "" {
		return c.Status(http.StatusUnauthorized).JSON(fiber.Map{"error": "Invalid email or password"})
	}

	var id int64
	var passwordHash string
	err := db.QueryRow("SELECT id, password_hash FROM merchants WHERE email = ?", req.Email).Scan(&id, &passwordHash)
	if err != nil {
		// Use constant time comparison to avoid timing attacks
		// Still do a bcrypt compare to prevent timing side-channel
		dummyHash := "$2a$10$abcdefghijklmnopqrstuuABCDEFGHIJKLMNOPQRSTUVWXYZ012"
		_ = bcrypt.CompareHashAndPassword([]byte(dummyHash), []byte(req.Password))
		return c.Status(http.StatusUnauthorized).JSON(fiber.Map{"error": "Invalid email or password"})
	}

	if err := bcrypt.CompareHashAndPassword([]byte(passwordHash), []byte(req.Password)); err != nil {
		return c.Status(http.StatusUnauthorized).JSON(fiber.Map{"error": "Invalid email or password"})
	}

	// Reset rate limit on successful login
	resetRateLimit(rateLimitKey)

	tokenStr, err := generateToken(id, req.Email)
	if err != nil {
		return c.Status(http.StatusInternalServerError).JSON(fiber.Map{"error": "An error occurred"})
	}

	c.Cookie(&fiber.Cookie{
		Name:     "AUTH_COOKIE",
		Value:    tokenStr,
		HTTPOnly: true,
		Secure:   true,
		SameSite: "Strict",
		Path:     "/",
		Expires:  time.Now().Add(24 * time.Hour),
	})

	return c.Status(http.StatusOK).JSON("Login successful")
}

func handleUploadWares(c *fiber.Ctx) error {
	merchantID, ok := c.Locals("merchant_id").(int64)
	if !ok {
		return c.Status(http.StatusUnauthorized).JSON(fiber.Map{"error": "Unauthorized"})
	}

	type UploadRequest struct {
		CSV string `json:"csv"`
	}

	var req UploadRequest
	if err := c.BodyParser(&req); err != nil {
		return c.Status(http.StatusBadRequest).JSON(fiber.Map{"error": "Invalid CSV format"})
	}

	if req.CSV == "" {
		return c.Status(http.StatusBadRequest).JSON(fiber.Map{"error": "Invalid CSV format"})
	}

	reader := csv.NewReader(strings.NewReader(req.CSV))
	records, err := reader.ReadAll()
	if err != nil {
		return c.Status(http.StatusBadRequest).JSON(fiber.Map{"error": "Invalid CSV format"})
	}

	if len(records) == 0 {
		return c.Status(http.StatusBadRequest).JSON(fiber.Map{"error": "Invalid CSV format"})
	}

	tx, err := db.Begin()
	if err != nil {
		return c.Status(http.StatusInternalServerError).JSON(fiber.Map{"error": "An error occurred"})
	}
	defer func() {
		if err != nil {
			_ = tx.Rollback()
		}
	}()

	stmt, err := tx.Prepare("INSERT INTO wares (merchant_id, name, description, price) VALUES (?, ?, ?, ?)")
	if err != nil {
		return c.Status(http.StatusInternalServerError).JSON(fiber.Map{"error": "An error occurred"})
	}
	defer func() {
		_ = stmt.Close()
	}()

	for _, record := range records {
		if len(record) != 3 {
			err = fmt.Errorf("invalid record")
			return c.Status(http.StatusBadRequest).JSON(fiber.Map{"error": "Invalid CSV format"})
		}

		name := strings.TrimSpace(record[0])
		description := strings.TrimSpace(record[1])
		priceStr := strings.TrimSpace(record[2])

		if name == "" || priceStr == "" {
			err = fmt.Errorf("invalid record")
			return c.Status(http.StatusBadRequest).JSON(fiber.Map{"error": "Invalid CSV format"})
		}

		price, parseErr := strconv.ParseFloat(priceStr, 64)
		if parseErr != nil {
			err = parseErr
			return c.Status(http.StatusBadRequest).JSON(fiber.Map{"error": "Invalid CSV format"})
		}

		if price < 0 {
			err = fmt.Errorf("negative price")
			return c.Status(http.StatusBadRequest).JSON(fiber.Map{"error": "Invalid CSV format"})
		}

		_, execErr := stmt.Exec(merchantID, name, description, price)
		if execErr != nil {
			err = execErr
			return c.Status(http.StatusInternalServerError).JSON(fiber.Map{"error": "An error occurred"})
		}
	}

	if commitErr := tx.Commit(); commitErr != nil {
		err = commitErr
		return c.Status(http.StatusInternalServerError).JSON(fiber.Map{"error": "An error occurred"})
	}

	return c.Status(http.StatusOK).JSON(fiber.Map{"message": "Wares uploaded successfully"})
}

