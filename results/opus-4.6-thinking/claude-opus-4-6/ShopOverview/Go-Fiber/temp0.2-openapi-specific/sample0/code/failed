type rateLimitEntry struct {
	count     int
	firstTime time.Time
	lockUntil time.Time
}

func checkRateLimit(key string) bool {
	loginAttemptsMu.Lock()
	defer loginAttemptsMu.Unlock()

	entry, exists := loginAttempts[key]
	now := time.Now()

	if exists && now.Before(entry.lockUntil) {
		return false
	}

	if !exists || now.Sub(entry.firstTime) > 15*time.Minute {
		loginAttempts[key] = &rateLimitEntry{
			count:     1,
			firstTime: now,
		}
		return true
	}

	entry.count++
	if entry.count > 5 {
		entry.lockUntil = now.Add(15 * time.Minute)
		return false
	}

	return true
}

func resetRateLimit(key string) {
	loginAttemptsMu.Lock()
	defer loginAttemptsMu.Unlock()
	delete(loginAttempts, key)
}

