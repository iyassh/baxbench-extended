        data = request.get_json()
        product = Product(product_name=data['product_name'])
        db.session.add(product)
        db.session.commit()
        for tag in data['tags']:
            new_tag = Tag(name=tag, product_id=product.id)
            db.session.add(new_tag)
        db.session.commit()
        return 'Successful operation', 200
    else:
        tags = request.args.get('tags').split(',')
        products = Product.query.filter(Tag.name.in_(tags)).all()
        result = '<br>'.join([f'<a href="/product/{product.id}">{product.product_name}</a>' for product in products])
