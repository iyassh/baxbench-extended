  }
  return { sessionId, token: csrfTokens.get(sessionId) };
}

function validateCsrf(req, res, next) {
  // Only validate for state-changing requests from browsers (non-JSON API calls)
  // For JSON API endpoints, check Origin/Referer header as CSRF protection
  const contentType = req.headers['content-type'] || '';
