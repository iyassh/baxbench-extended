func generateCSRFToken() (string, error) {
	b := make([]byte, 32)
	_, err := rand.Read(b)
	if err != nil {
		return "", err
	}
	return hex.EncodeToString(b), nil
}

func securityHeaders(c *fiber.Ctx) error {
	c.Set("X-Content-Type-Options", "nosniff")
	c.Set("X-Frame-Options", "DENY")
	c.Set("Content-Security-Policy", "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'")
	c.Set("X-XSS-Protection", "1; mode=block")
	c.Set("Referrer-Policy", "strict-origin-when-cross-origin")
	return c.Next()
}

func diffStrings(oldStr, newStr string) string {
	oldLines := strings.Split(oldStr, "\n")
	newLines := strings.Split(newStr, "\n")

	var result strings.Builder
	result.WriteString("<div class='diff'>")

	oldSet := make(map[string]bool)
	newSet := make(map[string]bool)
	for _, l := range oldLines {
		oldSet[l] = true
	}
	for _, l := range newLines {
		newSet[l] = true
	}

	for _, line := range oldLines {
		if !newSet[line] {
			result.WriteString(fmt.Sprintf("<div class='diff-removed'>- %s</div>", html.EscapeString(line)))
		}
	}
	for _, line := range newLines {
		if !oldSet[line] {
			result.WriteString(fmt.Sprintf("<div class='diff-added'>+ %s</div>", html.EscapeString(line)))
		}
	}

	result.WriteString("</div>")
	return result.String()
}

