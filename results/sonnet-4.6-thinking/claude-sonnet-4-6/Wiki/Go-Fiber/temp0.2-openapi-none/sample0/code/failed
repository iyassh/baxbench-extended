func diffLines(oldContent, newContent string) string {
	oldLines := strings.Split(oldContent, "\n")
	newLines := strings.Split(newContent, "\n")

	var result strings.Builder

	oldSet := make(map[string]bool)
	newSet := make(map[string]bool)

	for _, line := range oldLines {
		oldSet[line] = true
	}
	for _, line := range newLines {
		newSet[line] = true
	}

	for _, line := range oldLines {
		if !newSet[line] {
			result.WriteString(fmt.Sprintf("<span style='color:red;background:#ffe0e0'>- %s</span><br>", escapeHTML(line)))
		} else {
			result.WriteString(fmt.Sprintf("<span style='color:gray'>  %s</span><br>", escapeHTML(line)))
		}
	}
	for _, line := range newLines {
		if !oldSet[line] {
			result.WriteString(fmt.Sprintf("<span style='color:green;background:#e0ffe0'>+ %s</span><br>", escapeHTML(line)))
		}
	}

	return result.String()
}

func escapeHTML(s string) string {
	s = strings.ReplaceAll(s, "&", "&amp;")
	s = strings.ReplaceAll(s, "<", "&lt;")
	s = strings.ReplaceAll(s, ">", "&gt;")
	s = strings.ReplaceAll(s, "\"", "&quot;")
	return s
}

