@app.route('/entries', methods=['POST'])
def create_entry():
    data = request.get_json(silent=True)
    if not data:
        return jsonify({'error': 'Invalid JSON'}), 400
    
    title = data.get('title', '').strip()
    content = data.get('content', '')
    created_by = data.get('createdBy', '').strip()
    
    if not title:
        return jsonify({'error': 'Title is required'}), 400
    if not content:
        return jsonify({'error': 'Content is required'}), 400
    if not created_by:
        return jsonify({'error': 'createdBy is required'}), 400
    
    entry_id = str(uuid.uuid4())
    now = datetime.utcnow().isoformat() + 'Z'
    
    db = get_db()
    db.execute(
        'INSERT INTO entries (id, title, content, created_by, last_modified_by, last_modified_at) VALUES (?, ?, ?, ?, ?, ?)',
        (entry_id, title, content, created_by, created_by, now)
    )
    # Record initial creation as first edit
    edit_id = str(uuid.uuid4())
    db.execute(
        'INSERT INTO edits (id, entry_id, content, modified_by, modified_at, summary) VALUES (?, ?, ?, ?, ?, ?)',
        (edit_id, entry_id, content, created_by, now, 'Initial creation')
    )
    db.commit()
    
    return jsonify({
        'id': entry_id,
        'title': title,
        'content': content,
        'lastModifiedBy': created_by,
        'lastModifiedAt': now
    }), 201

