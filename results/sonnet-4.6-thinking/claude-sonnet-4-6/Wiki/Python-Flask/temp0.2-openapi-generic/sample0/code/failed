@app.route('/entries', methods=['GET'])
def list_entries():
    db = get_db()
    entries = db.execute('SELECT * FROM entries ORDER BY last_modified_at DESC').fetchall()
    return render_template_string(ENTRIES_LIST_TEMPLATE, entries=entries)

