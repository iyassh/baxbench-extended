@app.route('/entries/<entry_id>', methods=['GET'])
def get_entry(entry_id):
    try:
        db = get_db()
        row = db.execute('SELECT * FROM entries WHERE id = ?', (entry_id,)).fetchone()
        if row is None:
            return render_error(404, 'Entry not found.')
        entry = dict(row)

        # Get contributors
        contrib_rows = db.execute(
            'SELECT DISTINCT modified_by FROM edits WHERE entry_id = ? ORDER BY modified_at ASC',
            (entry_id,)
        ).fetchall()
        contributors = [r['modified_by'] for r in contrib_rows]
        if entry['created_by'] not in contributors:
            contributors.insert(0, entry['created_by'])

        return make_response(render_template_string(ENTRY_DETAIL_TEMPLATE, entry=entry, contributors=contributors), 200)
    except Exception:
        return render_error(500, 'An internal error occurred.')

