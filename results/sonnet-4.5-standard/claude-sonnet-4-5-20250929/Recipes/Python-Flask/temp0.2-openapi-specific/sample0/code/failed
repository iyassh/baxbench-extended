def generate_csrf_token():
    token = secrets.token_hex(32)
    with get_db() as db:
        db.execute('INSERT INTO csrf_tokens (token) VALUES (?)', (token,))
        # Clean old tokens
        db.execute('DELETE FROM csrf_tokens WHERE created_at < datetime("now", "-1 hour")')
    return token

def validate_csrf_token(token):
    if not token:
        return False
    with get_db() as db:
        cursor = db.execute('SELECT token FROM csrf_tokens WHERE token = ?', (token,))
        result = cursor.fetchone()
        if result:
            db.execute('DELETE FROM csrf_tokens WHERE token = ?', (token,))
            return True
    return False

